<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandboxing deshabilitado para desarrollo (habilitar en producción) -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Acceso a red (necesario para navegador) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Bluetooth para passkeys cross-device -->
    <key>com.apple.security.device.bluetooth</key>
    <true/>

    <!-- Keychain para almacenar credenciales -->
    <key>com.apple.security.keychain-access-groups</key>
    <array>
        <string>com.mai.browser</string>
    </array>

    <!-- Cámara (para videollamadas y Face ID) -->
    <key>com.apple.security.device.camera</key>
    <true/>

    <!-- Micrófono (para llamadas de voz/video) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- USB (para llaves de seguridad físicas como YubiKey) -->
    <key>com.apple.security.device.usb</key>
    <true/>

    <!-- Hardened Runtime: NO incluir estas excepciones (anti-RE):
         - com.apple.security.cs.allow-dyld-environment-variables  (bloquea DYLD_INSERT_LIBRARIES)
         - com.apple.security.cs.allow-unsigned-executable-memory   (bloquea JIT no autorizado)
         - com.apple.security.get-task-allow                        (bloquea task_for_pid debugging)
    -->

    <!-- Permitir JIT solo para WebKit/CEF (requerido para JavaScript engine) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Permitir cargar libraries con firma diferente (requerido para CEF ad-hoc signing).
         macOS 26 hardened runtime rechaza dlopen de Chromium Embedded Framework porque
         su firma ad-hoc tiene identidad diferente a la del binario principal.
         Sin Apple Developer ID, no hay forma de firmar ambos con el mismo Team ID.
         NOTA: Cuando se tenga Developer ID, remover esto y firmar todo con el mismo identity. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
